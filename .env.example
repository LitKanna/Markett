# Copy to .dev.vars for local wrangler dev (never commit real values).

# IndexNow — optional override of default key in infra/seo-indexnow.mjs
# INDEXNOW_KEY=

# Google Search Console — HTML tag verification (injected into HTML by the worker)
# GOOGLE_SITE_VERIFICATION=your_meta_content_value_from_search_console

# Google Search Console API — full service account JSON (CI / npm run seo:google)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Higgsfield — design asset generation (npm run higgsfield:sync)
# Create keys at https://cloud.higgsfield.ai/api-keys
# HF_CREDENTIALS=KEY_ID:KEY_SECRET
# HF_API_KEY=
# HF_API_SECRET=
